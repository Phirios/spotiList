# Required: Spotify app credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered in the Spotify app dashboard
SPOTIFY_REDIRECT_URI=https://spoti.phirios.com/api/auth/callback

# Where the user lands after a successful login
WEB_URL_AFTER_LOGIN=https://spoti.phirios.com/dashboard

# Required: Postgres connection string
DATABASE_URL=postgres://spoti:CHANGE_ME@localhost:5432/spoti

# Required: at least 32 bytes, used to derive cookie signing+encryption keys
SESSION_SECRET=

# Set to true behind HTTPS (production); false for localhost dev
COOKIE_SECURE=false

# Optional: GetSongBPM API key (https://getsongbpm.com/api). Without this, BPM is null.
GETSONGBPM_API_KEY=

# Optional: Last.fm API key (https://www.last.fm/api). Used to enrich genres.
LASTFM_API_KEY=

# Optional
BIND_ADDR=0.0.0.0:8080
USER_AGENT=spoti-backend/0.1 (https://spoti.phirios.com)
RUST_LOG=info,spoti_backend=debug
